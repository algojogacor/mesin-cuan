# ─────────────────────────────────────────
# MESIN CUAN VIRAL ARCHITECT — Environment Variables
# Salin file ini → rename menjadi ".env" → isi nilainya.
# ⚠️  JANGAN PERNAH commit file .env ke Git!
# ─────────────────────────────────────────

# ── AI PROVIDERS ─────────────────────────────────────────────
# Google Gemini (utama / primary AI)
GEMINI_API_KEY=

# Groq (LLM cepat / fast LLM — llama3, mixtral)
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# Anthropic Claude (fallback AI)
ANTHROPIC_API_KEY=

# Ollama (lokal / local LLM — tidak perlu key)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.3:latest

# Qwen self-hosted (Dual Parallel Generation)
# Ganti dengan endpoint Qwen kamu:
QWEN_API_BASE=http://localhost:9000/v1
QWEN_API_KEY=
QWEN_MODEL=qwen3-235b-a22b
QWEN_MODEL_CANDIDATES=qwen3-235b-a22b,qwen3-plus,qwen2.5-72b-instruct,qwen3-30b-a3b,qwen3-turbo,qwen3.6-plus
QWEN_TIMEOUT=600
SCRIPT_MAX_TOKENS_SHORTS=2400
SCRIPT_MAX_TOKENS_LONGFORM=7000
SCRIPT_REVIEW_MAX_TOKENS=3200
HOOK_MIN_SCORE=8.7
SCRIPT_QUALITY_THRESHOLD=8.2
SHORTS_REVIEW_MIN_SCORE=9.2
VIRAL_VIEW_THRESHOLD=100000

# NVIDIA NIM API (opsional / optional — gratis)
NVIDIA_API_KEY=

# AssemblyAI (transkrip podcast — opsional)
ASSEMBLYAI_API_KEY=

# Web Research Engine (Perplexity — opsional, graceful skip jika kosong)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=

# ── TTS ──────────────────────────────────────────────────────
# F5-TTS, Edge TTS, Coqui — pilih mode: f5 / edge / coqui
TTS_MODE=f5
# ElevenLabs (opsional — suara premium)
ELEVENLABS_API_KEY=

# ── FOOTAGE ──────────────────────────────────────────────────
# Pexels (B-roll footage & foto)
PEXELS_API_KEY=
# Pixabay (footage fallback)
PIXABAY_API_KEY=
# Coverr (stock video gratis)
COVERR_API_KEY=
COVERR_APP_ID=

# Freesound (SFX otomatis / auto SFX — opsional)
FREESOUND_API_KEY=

# Cache footage (detik) — 7 hari = 604800
FOOTAGE_CACHE_TTL=604800

# ── MUSIC ────────────────────────────────────────────────────
AUTO_MUSIC_ENRICH_LOCAL=true
AUTO_MUSIC_PROMOTE_FETCHED=true
LOCAL_MUSIC_MIN_TRACKS=10
MUSIC_AI_SELECTION=true
MUSIC_SELECTION_MAX_CANDIDATES=10

# ── RENDERING ────────────────────────────────────────────────
# Pilihan preset: fast (cepat) / slow (cinematic) / preview (test)
RENDER_PRESET=fast
# Folder output hasil render
RENDER_OUTPUT_DIR=output/videos
# Folder cache footage
FOOTAGE_CACHE_DIR=cache/footage

# ── YOUTUBE & GOOGLE ─────────────────────────────────────────
# YouTube Data API v3 (trending & upload)
YOUTUBE_API_KEY=

# YouTube Upload Settings
YOUTUBE_UPLOAD_PLAYLIST_ID=
DAILY_UPLOAD_LIMIT=12

# OAuth2 credentials (dari Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_ID=

# YouTube Analytics (Opsional — untuk retention dashboard)
YOUTUBE_ANALYTICS_SCOPES=https://www.googleapis.com/auth/yt-analytics.readonly

# ── CLOUDFLARE BROWSER RENDERING ─────────────────────────────
# Untuk scraping Google Trends
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── TELEGRAM NOTIFICATIONS ───────────────────────────────────
# Buat bot di @BotFather → dapatkan token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── ADVANCED / RETRY & LOGGING ───────────────────────────────
# Auto-retry jika gagal
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=60

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Multi-channel config (opsional)
CHANNEL_CONFIG_PATH=config/channels.json

